{
  "name": "agentme",
  "version": "0.0.1",
  "description": "",
  "dependencies": {
    "npmdata": "^0.20.1",
    "xdrs-core": "^0.3.6"
  },
  "bin": "bin/npmdata.js",
  "files": [
    "package.json",
    "bin/npmdata.js",
    ".xdrs/agentme/**",
    ".xdrs/index.md",
    ".github/agents/speckit*",
    ".github/prompts/speckit*",
    ".specify/**",
    ".vscode/settings.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flaviostutz/agentme.git"
  },
  "npmdata": {
    "sets": [
      {
        "package": "xdrs-core",
        "selector": {
          "files": [
            ".xdrs/_core/**",
            "AGENTS.md"
          ]
        },
        "output": {
          "path": ".",
          "gitignore": false
        },
        "presets": [
          "basic"
        ]
      },
      {
        "selector": {
          "files": [
            ".xdrs/agentme/**"
          ]
        },
        "output": {
          "path": ".",
          "gitignore": false
        },
        "presets": [
          "basic"
        ]
      },
      {
        "selector": {
          "files": [
            ".xdrs/index.md"
          ]
        },
        "output": {
          "path": ".",
          "managed": false,
          "skipIfExists": true,
          "gitignore": false
        },
        "presets": [
          "basic"
        ]
      },
      {
        "selector": {
          "files": [
            ".github/agents/speckit*",
            ".github/prompts/speckit*",
            ".specify/**"
          ]
        },
        "output": {
          "path": ".",
          "gitignore": false
        },
        "presets": [
          "speckit"
        ]
      },
      {
        "selector": {
          "files": [
            ".vscode/settings.json"
          ]
        },
        "output": {
          "path": ".",
          "managed": false,
          "skipIfExists": true,
          "gitignore": false
        },
        "presets": [
          "speckit"
        ]
      }
    ]
  }
}
